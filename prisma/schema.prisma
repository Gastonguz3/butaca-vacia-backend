generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
  moduleFormat = "cjs"  //Por defecto esta como: moduleFormat = "esm" 
}

// Primero: docker compose up -d
// Luego: pnpm dlx prisma migrate dev ->  Crear las tablas en la Base de Datos (Migración)
// Luego: pnpm dlx prisma generate  -> Generar el Prisma Client (Si no se hizo automaticamente)

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
}


model User {
  id String @id @default(uuid())
  email String @unique
  username String @unique
  password String

  
  role Role @default(USER)
  refreshToken String?

  //Relacion
  reviews Review[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@index([email])
  @@map("usuarios")  // nombre de la tabla
}

enum MediaType {
  MOVIE
  SERIES
}

model Review {
  id String @id @default(uuid())
  rating Int
  comment String
  tmdbId     Int  //Identifico la pelicula/serie real en TMDB
  mediaType  MediaType
  titleShow String

  //Relacion
  userId String
  user User @relation(fields: [userId], references: [id], onDelete: Cascade )

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, tmdbId, mediaType]) //para que cada usuario deje un solo review por pelicula o serie
  @@index([userId])
  @@map("comentarios")
}
